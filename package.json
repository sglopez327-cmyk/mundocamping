{
  "name": "mundo-camping",
  "private": true,
  "scripts": {
    "build:fonts": "node scripts/copy-fonts.mjs",
    "build:css": "tailwindcss -i ./src/tailwind.css -o ./css/tailwind-built.css --minify",
    "build:home-guides": "node scripts/generate-home-guides.mjs",
    "build": "npm run build:fonts && npm run build:css && npm run build:home-guides",
    "predeploy": "npm run build",
    "postinstall": "npm run build:fonts"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.5",
    "@fontsource/plus-jakarta-sans": "^5.2.5",
    "@fontsource/playfair-display": "^5.2.5"
  }
}
